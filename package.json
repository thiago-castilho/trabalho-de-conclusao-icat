{
  "name": "trabalho-de-conclusao-icat",
  "version": "1.0.0",
  "description": "Os requisitos e critérios de avaliação deste trabalho podem ser consultados em:",
  "main": "index.js",
  "scripts": {
    "test": "npx mocha",
    "report": "npx mocha --reporter mochawesome",
    "lint:check": "prettier --check --ignore-path .gitignore .",
    "lint:format": "prettier --write --ignore-path .gitignore .",
    "prepare": "husky",
    "commit": "git-cz"
  },
  "config": {
    "commitizen": {
      "path": "cz-git"
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write --ignore-path .gitignore ."
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thiago-castilho/trabalho-de-conclusao-icat.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/thiago-castilho/trabalho-de-conclusao-icat/issues"
  },
  "homepage": "https://github.com/thiago-castilho/trabalho-de-conclusao-icat#readme",
  "dependencies": {
    "mocha": "^8.1.3",
    "mochawesome": "^7.1.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "commitizen": "^4.3.1",
    "cz-git": "^1.13.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "3.8.3"
  }
}
